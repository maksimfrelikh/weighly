# backend/.env.example — local dev (running the backend directly without docker)
#
# Copy to `backend/.env` and fill in the placeholders. For running the full
# stack via docker compose, see the root-level `.env.example` instead (compose
# reads `.env` adjacent to `docker-compose.yml`, not this file).
#
#   cp backend/.env.example backend/.env
#   $EDITOR backend/.env
#   npm --prefix backend run start:dev
#
# The backend refuses to start at boot when any required variable below is
# missing, empty, malformed, or — in production — set to the historical
# insecure default `scale_admin_password`.

NODE_ENV=development
PORT=3000
# DATABASE_URL: required. The literal below is a LOCAL DEV ONLY convenience
# matching the docker-compose Postgres credentials for fresh checkouts.
# Production deployments MUST use a strong random password (see root .env.example).
DATABASE_URL=postgresql://scale_admin:scale_admin_password@localhost:5432/scale_admin
FRONTEND_ORIGIN=http://localhost:5173
# EMAIL_PROVIDER: disabled | resend. Use disabled for local dev without mail.
EMAIL_PROVIDER=disabled
EMAIL_FROM="Scale Admin <invites@maksimfrelikh.ru>"
EMAIL_REPLY_TO="frelikhmax@gmail.com"
# Required only when EMAIL_PROVIDER=resend. Backend-only secret; do not prefix with VITE_.
RESEND_API_KEY=
SESSION_COOKIE_NAME=scale_admin_session
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_DAYS=14
CSRF_COOKIE_NAME=scale_admin_csrf
CSRF_HEADER_NAME=x-csrf-token
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_ACTION_RATE_LIMIT_MAX=10
AUTH_FAILED_LOGIN_MAX_ATTEMPTS=5
AUTH_FAILED_LOGIN_LOCK_MINUTES=15
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
# Local uploaded files directory. Docker Compose overrides this to /app/uploads and mounts a persistent volume there.
FILE_UPLOAD_DIR=uploads

# Local development seed defaults. Override these before seeding shared/non-local databases.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_FULL_NAME=Local Admin
# Set to true only when you intentionally want the seed to rotate the existing admin password.
SEED_ADMIN_RESET_PASSWORD=false
