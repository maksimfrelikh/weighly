# scale-admin — docker compose environment template
#
# Copy this file to `.env` (same directory as docker-compose.yml) and replace every
# `CHANGE_ME_*` placeholder before running `docker compose up`. Compose itself will
# refuse to start when any required variable below is missing or empty.
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose up -d
#
# For per-environment overrides (e.g. staging), see docker-compose.staging.yml and
# keep its `.env.staging` populated with the same variable set.

# ── Runtime ──────────────────────────────────────────────────────────────────
# NODE_ENV: development | test | production
NODE_ENV=production

# Backend listens on this port inside the container.
PORT=3000

# Public origin (scheme + host) of the SPA. Must be http(s); used by CORS.
# Required for CORS to function; mismatched origin will block all browser calls.
# Also used as the trusted base URL for invite and password-reset email links.
FRONTEND_ORIGIN=https://CHANGE_ME.example.com

# Frontend build arg. Empty value means the SPA uses relative `/api/...` paths
# (typical when nginx fronts both backend and frontend). Set to an absolute URL
# only if frontend and backend live on different origins.
VITE_API_BASE_URL=

# ── Email (backend only — never expose RESEND_API_KEY as VITE_*) ─────────────
# EMAIL_PROVIDER: disabled | resend. Use disabled for local/dev without mail.
# Set to resend in staging/prod only after RESEND_API_KEY is populated.
EMAIL_PROVIDER=disabled
EMAIL_FROM="Scale Admin <invites@maksimfrelikh.ru>"
EMAIL_REPLY_TO="frelikhmax@gmail.com"
# Required only when EMAIL_PROVIDER=resend. Set only in backend/server environments.
RESEND_API_KEY=

# ── Database (REQUIRED — no defaults; compose refuses to start without these) ─
POSTGRES_DB=scale_admin
POSTGRES_USER=scale_admin
# Required. Use a long random string — do NOT reuse the historical insecure
# default (`scale_admin_password`). Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_RANDOM_SECRET
# Required. Must reference the same credentials as POSTGRES_USER/PASSWORD above
# (compose links the backend container to the `postgres` service hostname).
DATABASE_URL=postgresql://scale_admin:CHANGE_ME_GENERATE_RANDOM_SECRET@postgres:5432/scale_admin

# ── Sessions / CSRF (optional — sensible defaults; override per environment) ──
SESSION_COOKIE_NAME=scale_admin_session
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_DAYS=14
CSRF_COOKIE_NAME=scale_admin_csrf
CSRF_HEADER_NAME=x-csrf-token

# ── Auth rate limits (optional — see backend/src/auth for behaviour) ──────────
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_ACTION_RATE_LIMIT_MAX=10
AUTH_FAILED_LOGIN_MAX_ATTEMPTS=5
AUTH_FAILED_LOGIN_LOCK_MINUTES=15
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# ── Files ─────────────────────────────────────────────────────────────────────
# Path inside the backend container where uploads are persisted (named volume).
FILE_UPLOAD_DIR=/app/uploads

# ── Build provenance (set by deploy scripts — leave blank for local dev) ──────
BUILD_SHA=
BUILT_AT=
